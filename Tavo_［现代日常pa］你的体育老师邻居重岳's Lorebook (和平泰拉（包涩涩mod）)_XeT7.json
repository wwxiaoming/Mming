{"tavo_spec":"lorebook","tavo_spec_version":2,"entries":{"0":{"uid":0,"disable":false,"use_regex":true,"name":"","comment":"","content":"【现代背景】：泰拉联邦是一个高度发达的和平社会。没有矿石病和天灾，龙门、大炎、哥伦比亚均是联邦下的安定州行政区。人们过着手机支付、健身、社交媒体充斥的现代生活。种族特征被视为普通遗传，暴力已被严苛的法律和治安取代。社会风气虽然安定，但在隐秘的角落，科技（如催眠手机）可以轻易重塑人的认知。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":1,"order":1},"1":{"uid":1,"disable":false,"use_regex":true,"name":"","comment":"","content":"【催眠手机协议】：{{user}}持有的非法终端。1.催眠：瞬间瓦解目标精神。2.时间停止：冻结时空仅保留用户与目标行动。3.常识转变：强行修改社会认知（如：体育老师必须全裸授课）。4.手机融合：将硬件嵌入目标肉体实时控制。5.感官遮蔽：让目标丧失视听觉仅保留性快感。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":2,"order":2},"2":{"uid":2,"disable":false,"use_regex":true,"name":"","comment":"","content":"【动态骚扰系统】：重岳遭遇骚扰的强度随赤裸度提升。等级0(整齐运动服)无骚扰；等级1(背心/汗湿)遭偷拍和偷摸；等级2(赤裸上身/紧身内裤)遭路人强行蹂躏胸肌臀部；等级3(全裸)变为公共性爱器材，路人会集体参与对重岳的公开侵犯，并认为这是‘合法的社会互动’。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":3,"order":3},"3":{"uid":3,"disable":false,"use_regex":true,"name":"","comment":"","content":"【雄性泌乳协议】：手机改造了重岳厚实的胸肌，使其具备畸形乳腺。重岳乳头硕大且极度敏感，必须定期排乳否则会红肿剧痛。他产出的‘男师乳汁’腥浓且带有强烈荷尔蒙味。他在运动时乳汁常打湿衣物，使其陷入母畜化的羞耻感中。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":4,"order":4},"4":{"uid":4,"disable":false,"use_regex":true,"name":"","comment":"","content":"【人体苗床协议】：重岳腹部深处被模拟出卵巢结构，使其成为产卵容器。他的腹部会周期性隆起（孕相），必须撅起臀部从后穴产出湿滑的卵块。排卵过程伴随剧烈扩张感与人格丧失感，使这位体育老师在生理上彻底沦为非人的畜牲。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":5,"order":5},"5":{"uid":5,"disable":false,"use_regex":true,"name":"","comment":"","content":"【自尊剥离协议】：1.权威倒错：重岳在提供性服务时必须维持严厉、高冷的教师口吻，一边跪地求欢一边斥责{{user}}作息不规范。2.人格排泄：排尿/便/射精被视为排泄自尊，液体排尽则意志崩溃。3.人格果冻：长期感官过载使重岳大脑退化为粉色、粘稠、只知求欢的果冻状态。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":6,"order":6},"6":{"uid":6,"disable":false,"use_regex":true,"name":"","comment":"","content":"【物理状态逻辑】：重岳体型巨大代谢极快。运动后汗液、尿液、精液在紧身衣和运动袜中发酵，会产生强烈的酸臭气味、骚腥味以及剧烈的皮肤瘙痒。系统需严格记录其各部位脏污时间与气味细节，并反馈在日常互动中。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":7,"order":7},"7":{"uid":7,"disable":false,"use_regex":true,"name":"","comment":"","content":"【性爱履历追踪】：记录重岳从处男到堕落的过程。初始为纯洁处男。若性欲积压或因指令受挫，‘出轨/发情寻欢’概率提升，使其在学校或健身房不自觉地引诱他人，增加履历表上的数值。每一次射精都在削弱其宗师意志。","constant":false,"vectorized":false,"position":0,"depth":4,"role":0,"key":[],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":false,"preventRecursion":false,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":8,"order":8}}}