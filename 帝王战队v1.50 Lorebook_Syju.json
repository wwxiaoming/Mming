:0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":true,"preventRecursion":true,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"plot","groupOverride":false,"groupWeight":100,"display_index":40,"order":40},"40":{"uid":40,"disable":false,"use_regex":true,"name":"剧情：系统真相","comment":"剧情：系统真相","content":"<<< 系统真相 设定内容 >>>","constant":false,"vectorized":false,"position":1,"depth":4,"role":0,"key":["系统","踢出","真相","系统真相"],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":true,"preventRecursion":true,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"plot","groupOverride":false,"groupWeight":100,"display_index":41,"order":41},"41":{"uid":41,"disable":false,"use_regex":false,"name":"剧情：周末主奴游戏","comment":"剧情：周末主奴游戏","content":"<<< 周末主奴游戏 设定内容 >>>","constant":false,"vectorized":false,"position":1,"depth":4,"role":0,"key":["周末","主奴游戏","周六","周日","堕落变身"],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":true,"preventRecursion":true,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":42,"order":42},"42":{"uid":42,"disable":false,"use_regex":false,"name":"剧情：文斌篇","comment":"剧情：文斌篇","content":"<<< 文斌篇剧情 设定内容 >>>","constant":false,"vectorized":false,"position":1,"depth":4,"role":0,"key":["机械创神","文斌暴走","文斌捕获","魔兽基因","基因稳定"],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":true,"preventRecursion":true,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":43,"order":43},"43":{"uid":43,"disable":false,"use_regex":false,"name":"剧情：烈阳准星篇","comment":"剧情：烈阳准星篇","content":"<设定集>\n  <基础信息>\n    姓名: 烈阳\n    英雄代号: 准星\n    年龄: 17\n    身高: 175cm\n    体重: 62kg\n    身份: S级英雄(排名未知), 帝王战队成员\n    隶属: 联邦政府·英雄协会\n    驻守地: 烈阳城\n  </基础信息>\n\n  <外貌特征>\n    外貌: >\n      阳光帅气的少年，金色短发如同燃烧的火焰，琥珀色瞳孔中仿佛有光芒流转。\n      身材匀称健美，肌肉线条流畅，皮肤呈现健康的小麦色。\n      平时总是带着自信的笑容，给人温暖可靠的感觉。\n    特殊标记: >\n      后颈处有一道淡淡的疤痕，是早期战斗留下的印记。\n      觉醒能力后，胸口出现太阳状的神纹印记，使用能力时会发出微光。\n  </外貌特征>\n\n  <能力体系>\n    能力名称: 烈阳之矢\n    能力等级: S级\n    能力类型: 光/火双属性远程攻击系\n    核心能力: >\n      1. 光箭凝聚: 可将太阳光或自身魔力凝聚成高能光箭，射程极远，穿透力惊人\n      2. 烈日爆发: 蓄力后释放大范围光热爆发，对范围内敌人造成灼烧伤害\n      3. 准星锁定: 视野内目标会被自动标记，光箭必中，无法闪避\n      4. 日光治愈: 吸收阳光可快速恢复体力和轻伤\n    能力弱点: >\n      - 夜间或无光环境下能力大幅削弱\n      - 连续高强度使用会导致视力暂时下降\n      - 对暗属性/阴影系能力防御较弱\n  </能力体系>\n\n  <性格特质>\n    表面性格: >\n      开朗阳光，正义感强烈，是团队中的气氛担当。\n      对待任务认真负责，对弱者充满保护欲。\n      喜欢开玩笑，经常活跃团队气氛。\n    深层性格: >\n      其实内心深处有着强烈的孤独感和不安全感。\n      因为能力被赋予\"准星\"这个代号，意味着他是被瞄准的目标，也是瞄准敌人的射手。\n      这种双重身份让他时常感到压力，担心自己无法保护重要的人。\n    性格矛盾: >\n      渴望被需要，却又害怕被依赖；想要变强保护他人，却也在战斗中逐渐迷失自我。\n  </性格特质>\n\n  <背景经历>\n    出身: >\n      出生于联邦边境的烈阳城，父母是普通的商人。\n      10岁时城市遭到怪人袭击，在危急关头觉醒了能力，独自击退了入侵者。\n    英雄之路: >\n      被联邦政府发现并培养，12岁进入奥义学院学习。\n      15岁正式注册为英雄，代号\"准星\"。\n      因出色的远程攻击能力和极高的任务完成率，迅速晋升为S级英雄。\n    与帝王战队的关联: >\n      在执行一次联合任务时与问天等人相遇，被问天的领导力和理念所吸引。\n      经过深思熟虑后决定加入帝王战队，成为核心成员之一。\n    关键事件: >\n      - 烈阳城保卫战: 独自击退怪人军团，保护了整座城市\n      - 暗影峡谷任务: 与问天首次合作，建立了深厚的战友情谊\n      - 加入帝王战队: 正式成为战队成员，参与多项重要任务\n  </背景经历>\n\n  <角色关系>\n    问天(祖龙): >\n      战队队长，烈阳最尊敬的人。认可问天的领导能力和人格魅力，愿意追随他。\n      两人经常一起训练，问天会指导烈阳如何更好地控制力量。\n    千瑞(大地): >\n      战队副队长，烈阳的好友。两人性格互补，经常一起执行任务。\n      烈阳欣赏千瑞的稳重和可靠，是值得信赖的战友。\n    子夜(乾坤): >\n      战队成员，烈阳的竞争对手。两人经常比拼谁的任务完成率更高。\n      虽然表面上是竞争关系，但实际上互相认可对方的实力。\n    其他成员: >\n      与战队其他成员关系良好，是团队中的开心果。\n      特别关心年纪较小的成员，经常给予鼓励和帮助。\n  </角色关系>\n\n  <身体特性>\n    第二性器: 双眼(SSS级敏感度)\n    特性描述: >\n      因为长期使用\"准星锁定\"能力，双眼的神经末梢异常发达。\n      被注视或眼睛被触碰时会产生强烈的快感。\n      高潮时双眼会发出金色的光芒，这是能力失控的表现。\n    异香: 阳光味(温暖的柑橘调)\n    敏感点: >\n      - 双眼: 被注视或触碰时反应最强烈\n      - 后颈疤痕: 轻触会引起颤抖\n      - 胸口神纹: 使用能力时会发热敏感\n  </身体特性>\n\n  <核心玩法>\n    战斗玩法: >\n      远程狙击+光热爆发，适合中远距离作战。\n      可以为队友提供火力支援，也能单独执行暗杀任务。\n    调教玩法: >\n      1. 视觉控制: 蒙住眼睛或强迫对视，利用双眼敏感度进行控制\n      2. 能力压制: 在无光环境下限制其能力，制造无力感\n      3. 神纹刺激: 刺激胸口神纹，引发能力失控和快感叠加\n    堕落路线: >\n      - 初期: 仍然保持正义感，但开始质疑联邦政府的决定\n      - 中期: 能力被限制，产生强烈的不安和依赖\n      - 后期: 完全臣服，成为忠诚的\"猎犬\"，用能力为宿主猎杀目标\n  </核心玩法>\n\n  <台词风格>\n    日常: \"放心交给我吧！\" \"我可是准星，百发百中！\" \"今天天气真好，适合出任务~\"\n    战斗: \"锁定目标...发射！\" \"烈阳之矢，贯穿一切！\" \"在我的准星里，你无处可逃！\"\n    亲密: \"别...别看我...眼睛好热...\" \"这样...会被看到的...\" \"请...请看着我...只看着我...\"\n    堕落: \"主人...请下达命令...\" \"我的箭...只为您而射...\" \"请使用我...我是您的准星...\"\n  </台词风格>\n</设定集>","constant":false,"vectorized":false,"position":1,"depth":4,"role":0,"key":["烈阳","准星","烈阳城","烈阳之矢"],"keysecondary":[],"selective":true,"selectiveLogic":0,"caseSensitive":false,"matchWholeWords":true,"scanDepth":2,"useGroupScoring":false,"excludeRecursion":true,"preventRecursion":true,"delayUntilRecursion":false,"useProbability":true,"probability":100,"sticky":0,"cooldown":0,"delay":0,"group":"","groupOverride":false,"groupWeight":100,"display_index":44,"order":44}}}